{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && mkdir -p public",
  "installCommand": "npm install",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
