{
  "expo": {
    "name": "Vitala",
    "slug": "vitala",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vitala",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vitala.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Vitala uses your location to find nearby nurses, set your visit address, and dispatch emergency help.",
        "NSCameraUsageDescription": "Vitala uses the camera to capture your professional ID and a verification selfie.",
        "NSPhotoLibraryUsageDescription": "Vitala lets you choose a photo for your profile and verification.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vitala.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Vitala uses your location to find nearby nurses and dispatch emergency help."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Vitala uses the camera to capture your professional ID and a verification selfie."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vitala lets you choose a photo for your profile and verification."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0E7C6B"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.vitala.app",
          "enableGooglePay": true
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.11.0"
        }
      ],
      [
        "@badatgil/expo-mapbox-navigation",
        {
          "accessToken": "pk.eyJ1IjoibW9oYW1lZGJ6YSIsImEiOiJjbXAyM3NtazkwY2VzMnNxeXp0MWdqZnhpIn0.atkw_dqMmBEGIts_WbUrcA",
          "mapboxMapsVersion": "11.11.0"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://vitala-tau.vercel.app/api",
      "supabaseUrl": "https://dieuytwiwtjzkxeuxett.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRpZXV5dHdpd3Rqemt4ZXV4ZXR0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM3OTI3ODEsImV4cCI6MjA5OTM2ODc4MX0.p0w2oPwJovWOsqDYwyDmaTEXYM4JqhqzylpZnliktIU",
      "stripePublishableKey": "pk_test_51TjXM3C1XrjpLABrjMTrH8EW6lIqBcxt9gvSmN5HEQsCKMdeJ3j8PP3HcwOwVhTS9tLfXN5wdKTE3Aha32Fccee900K5jMKqqX",
