# Vitala mobile — runtime/build config. Copy to .env and fill in.
# EXPO_PUBLIC_* vars are inlined into the app bundle; others are read by the CLI only.

# Point the app at your running server-nest API.
# On a physical device use your machine's LAN IP, not localhost.
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Maps: iOS uses Apple Maps (no key needed). For Google Maps on Android, add your key to
# app.json -> android.config.googleMaps.apiKey. Stripe: set app.json extra.stripePublishableKey
# and the matching STRIPE_* secrets in server-nest/.env for live payments.
