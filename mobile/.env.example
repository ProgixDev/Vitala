# Vitala App Configuration
# Copy this file to .env and update with your local settings

# Backend API URL
# For development on physical device: use your machine's local IP (run 'ipconfig' on Windows or 'ifconfig' on Mac/Linux)
# For Android emulator: use http://10.0.2.2:5000
# For iOS simulator: use http://localhost:5000
# For production: use your deployed backend URL
EXPO_PUBLIC_API_URL=http://192.168.1.176:5000

# Example configurations:
# Local network (physical device): http://192.168.1.XXX:5000
# Android emulator: http://10.0.2.2:5000
# iOS simulator: http://localhost:5000
# Production: https://api.yourdomain.com
