# Vitala mobile — new NestJS API + Supabase auth
# Physical device: use your machine's LAN IP (e.g. http://192.168.1.20:4000)
EXPO_PUBLIC_API_URL=http://localhost:4000

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Mapbox (maps). Create at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token
